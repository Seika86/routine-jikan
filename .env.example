# ルーチン時間 — 環境変数テンプレート
# このファイルを .env にコピーして使ってください
# cp .env.example .env

# --- API ---

# データベースファイルのパス（デフォルト: file:./data/routine-jikan.db）
# DB_PATH=file:./data/routine-jikan.db

# APIトークン認証（未設定なら認証なし・ローカル開発向け）
# AUTH_TOKEN=your-secret-token

# --- Web (Vite) ---

# TTS サーバーのURL（AivisSpeech / VOICEVOX / OpenAI互換 — 自動検出）
# 未設定の場合、TTS プロキシは無効化されブラウザの Web Speech API のみ使用可能
# AivisSpeech のデフォルトポートは 10101
# VITE_TTS_URL=http://localhost:10101

# TTS ボタンの表示ラベル（デフォルト: "TTS Server"）
# VITE_TTS_LABEL=コウ🌊
